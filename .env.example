# ─────────────────────────────────────────────────────────────────────────────
# code-review-agent — environment configuration
#
# Copy this file to `.env` (in the same folder) and fill in your provider key:
#     cp .env.example .env
#
# `.env` is gitignored. Never commit a file containing real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Provider API keys (set ONE) ─────────────────────────────────────────────
# Auto-detection picks the first one that's set, in this order:
#   GROQ → ANTHROPIC → OPENAI → GEMINI → OLLAMA

# Groq (recommended — free tier, fast, supports tool use on llama-3.3-70b)
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic (paid) — uncomment if you want Claude
#ANTHROPIC_API_KEY=

# OpenAI (paid)
#OPENAI_API_KEY=

# Google Gemini
#GEMINI_API_KEY=

# Ollama (local, no key needed; just point at your daemon)
#OLLAMA_HOST=http://localhost:11434


# ─── Model overrides (optional) ──────────────────────────────────────────────
# Leave commented to use the default for your detected provider.
#
# REVIEWER_MODEL uses PydanticAI's `<provider>:<model>` format and drives the
# agentic investigation loop (tool use + structured output). SUMMARIZER_MODEL
# is just a model name (uses an OpenAI-compatible client) for cheap one-shot
# descriptions of undocumented code.

# Groq defaults
#REVIEWER_MODEL=groq:llama-3.3-70b-versatile
#SUMMARIZER_MODEL=llama-3.1-8b-instant

# Anthropic example
#REVIEWER_MODEL=anthropic:claude-sonnet-4-20250514

# OpenAI example
#REVIEWER_MODEL=openai:gpt-4o
#SUMMARIZER_MODEL=gpt-4o-mini

# Gemini example
#REVIEWER_MODEL=google-gla:gemini-1.5-pro
#SUMMARIZER_MODEL=gemini-1.5-flash

# Ollama example
#REVIEWER_MODEL=openai:llama3
#SUMMARIZER_MODEL=llama3
